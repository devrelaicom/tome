# Supply-chain hardening.
#
# pnpm reads this file too, so it deliberately contains ONLY settings that are
# identical to the pnpm/npm defaults — there is NO behavioural change to pnpm
# and nothing here can cause a pnpm false positive.
#
# The actual "do not use npm" enforcement lives in the preinstall guard
# (scripts/enforce-pnpm.mjs, wired via package.json). This file just pins the
# registry and requires TLS so a stray parent .npmrc or a dependency cannot
# silently redirect installs to another host.
#
# Intentionally NOT set: ignore-scripts (it would change pnpm's behaviour and
# would disable the preinstall guard itself) and save-exact (would change the
# pnpm `add` workflow). pnpm's own controls — minimumReleaseAge in
# pnpm-workspace.yaml and LavaMoat allowScripts in package.json — cover those.

registry=https://registry.npmjs.org/
strict-ssl=true
