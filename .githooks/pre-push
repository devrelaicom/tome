#!/bin/sh
# Tome — pre-push hook
#
# Runs the full test suite before a branch leaves the developer's machine.
# Constitution principle X says "no change lands on main without green CI";
# this hook is the local mirror of that — it catches failures before CI has
# to.
#
# Git invokes pre-push with stdin connected to a pipe carrying refspecs.
# Reading or ignoring that pipe is the hook's responsibility. We don't need
# the refspecs for `cargo test`, so we drain stdin and discard. This also
# decouples cargo test's stdio inheritance from git's pipe, avoiding a class
# of harness-wrapper deadlocks observed during Phase 2 slice 2 (see
# specs/002-phase-2-plugins-index/retro/P2.md).

set -e

# Drain stdin (git push pipes refspecs here).
cat > /dev/null

echo "▶ cargo test --workspace"
exec cargo test --workspace
