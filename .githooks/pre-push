#!/bin/sh
# Tome — pre-push hook
#
# Final local quality gate before a branch leaves the dev machine. Mirrors
# the pre-commit chain (cargo fmt / typos / clippy) so a --no-verify'd
# commit can't slip through. The full test suite + build matrix runs in CI
# on every PR (4-way OS × toolchain matrix, all features); duplicating it
# locally costs 30+ min for no signal CI doesn't already produce.
#
# Git invokes pre-push with stdin connected to a pipe carrying refspecs.
# Reading or ignoring that pipe is the hook's responsibility — we don't
# need the refspecs, so drain and discard. This also decouples downstream
# stdio inheritance from git's pipe (a class of harness-wrapper deadlocks
# observed during Phase 2 slice 2 — see
# specs/002-phase-2-plugins-index/retro/P2.md).

set -e

# Drain stdin (git push pipes refspecs here).
cat > /dev/null

echo "▶ cargo fmt --all -- --check"
cargo fmt --all -- --check

echo "▶ typos"
typos

echo "▶ cargo clippy --all-targets --all-features -- -D warnings"
cargo clippy --all-targets --all-features -- -D warnings
